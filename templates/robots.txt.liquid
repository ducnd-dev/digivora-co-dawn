{%- comment -%}
  Keep Shopify default robots rules so Shopify can update them over time.
{%- endcomment -%}
{%- for group in robots.default_groups -%}
{{- group.user_agent -}}

{%- for rule in group.rules -%}
{{ rule }}
{%- endfor -%}

{%- if group.sitemap != blank -%}
{{ group.sitemap }}
{%- endif -%}

{%- endfor -%}

