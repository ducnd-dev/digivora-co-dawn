{%- comment -%}
  Breadcrumb navigation + BreadcrumbList JSON-LD (SEO checklist #36).
  Use: {% render 'breadcrumb' %}
  Renders on: collection, product, blog, article, page (not homepage).
{%- endcomment -%}

{%- liquid
  assign show_breadcrumb = false
  if request.page_type == 'collection' and collection
    assign show_breadcrumb = true
  elsif request.page_type == 'product' and product
    assign show_breadcrumb = true
  elsif request.page_type == 'blog' and blog
    assign show_breadcrumb = true
  elsif request.page_type == 'article' and article and blog
    assign show_breadcrumb = true
  elsif request.page_type == 'page' and page
    assign show_breadcrumb = true
  endif
-%}

{%- if show_breadcrumb -%}
  {%- liquid
    assign home_label = 'general.breadcrumb.home' | t
    assign list_items = ''
    assign position = 0
    assign base_url = shop.url
    if request.locale.primary?
      assign locale_prefix = ''
    else
      assign locale_prefix = '/' | append: request.locale.iso_code
    endif
  -%}

  <nav class="breadcrumb" aria-label="{{ 'general.breadcrumb.label' | t }}">
    <div class="page-width">
      <ol class="breadcrumb__list" itemscope itemtype="https://schema.org/BreadcrumbList">
        {%- comment -%} Home (always first) {%- endcomment -%}
        <li class="breadcrumb__item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
          <a href="{{ routes.root_url }}" itemprop="item" class="breadcrumb__link link link--text underlined-link">
            <span itemprop="name">{{ home_label }}</span>
          </a>
          <meta itemprop="position" content="1">
        </li>

        {%- if request.page_type == 'collection' -%}
          <li class="breadcrumb__item breadcrumb__item--current" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
            <span itemprop="name">{{ collection.title | escape }}</span>
            <link itemprop="item" href="{{ collection.url }}">
            <meta itemprop="position" content="2">
          </li>

        {%- elsif request.page_type == 'product' -%}
          {%- if product.collection -%}
            <li class="breadcrumb__item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
              <a href="{{ product.collection.url }}" itemprop="item" class="breadcrumb__link link link--text underlined-link">
                <span itemprop="name">{{ product.collection.title | escape }}</span>
              </a>
              <meta itemprop="position" content="2">
            </li>
            <li class="breadcrumb__item breadcrumb__item--current" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
              <span itemprop="name">{{ product.title | escape }}</span>
              <link itemprop="item" href="{{ product.url }}">
              <meta itemprop="position" content="3">
            </li>
          {%- else -%}
            <li class="breadcrumb__item breadcrumb__item--current" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
              <span itemprop="name">{{ product.title | escape }}</span>
              <link itemprop="item" href="{{ product.url }}">
              <meta itemprop="position" content="2">
            </li>
          {%- endif -%}

        {%- elsif request.page_type == 'blog' -%}
          <li class="breadcrumb__item breadcrumb__item--current" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
            <span itemprop="name">{{ blog.title | escape }}</span>
            <link itemprop="item" href="{{ blog.url }}">
            <meta itemprop="position" content="2">
          </li>

        {%- elsif request.page_type == 'article' -%}
          <li class="breadcrumb__item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
            <a href="{{ blog.url }}" itemprop="item" class="breadcrumb__link link link--text underlined-link">
              <span itemprop="name">{{ blog.title | escape }}</span>
            </a>
            <meta itemprop="position" content="2">
          </li>
          <li class="breadcrumb__item breadcrumb__item--current" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
            <span itemprop="name">{{ article.title | escape }}</span>
            <link itemprop="item" href="{{ article.url }}">
            <meta itemprop="position" content="3">
          </li>

        {%- elsif request.page_type == 'page' -%}
          <li class="breadcrumb__item breadcrumb__item--current" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
            <span itemprop="name">{{ page.title | escape }}</span>
            <link itemprop="item" href="{{ page.url }}">
            <meta itemprop="position" content="2">
          </li>
        {%- endif -%}
      </ol>
    </div>
  </nav>

  {%- comment -%} BreadcrumbList JSON-LD for Rich Results {%- endcomment -%}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": {{ home_label | json }},
          "item": {{ shop.url | append: routes.root_url | json }}
        }
        {%- if request.page_type == 'collection' -%}
        ,{
          "@type": "ListItem",
          "position": 2,
          "name": {{ collection.title | escape | json }},
          "item": {{ shop.url | append: collection.url | json }}
        }
        {%- elsif request.page_type == 'product' -%}
        {%- if product.collection -%}
        ,{
          "@type": "ListItem",
          "position": 2,
          "name": {{ product.collection.title | escape | json }},
          "item": {{ shop.url | append: product.collection.url | json }}
        }
        ,{
          "@type": "ListItem",
          "position": 3,
          "name": {{ product.title | escape | json }},
          "item": {{ shop.url | append: product.url | json }}
        }
        {%- else -%}
        ,{
          "@type": "ListItem",
          "position": 2,
          "name": {{ product.title | escape | json }},
          "item": {{ shop.url | append: product.url | json }}
        }
        {%- endif -%}
        {%- elsif request.page_type == 'blog' -%}
        ,{
          "@type": "ListItem",
          "position": 2,
          "name": {{ blog.title | escape | json }},
          "item": {{ shop.url | append: blog.url | json }}
        }
        {%- elsif request.page_type == 'article' -%}
        ,{
          "@type": "ListItem",
          "position": 2,
          "name": {{ blog.title | escape | json }},
          "item": {{ shop.url | append: blog.url | json }}
        }
        ,{
          "@type": "ListItem",
          "position": 3,
          "name": {{ article.title | escape | json }},
          "item": {{ shop.url | append: article.url | json }}
        }
        {%- elsif request.page_type == 'page' -%}
        ,{
          "@type": "ListItem",
          "position": 2,
          "name": {{ page.title | escape | json }},
          "item": {{ shop.url | append: page.url | json }}
        }
        {%- endif -%}
      ]
    }
  </script>
{%- endif -%}
